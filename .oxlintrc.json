{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    // import順はautofixできないのでoxfmtに任せる
    "sort-imports": ["error", { "ignoreDeclarationSort": true }],
    "sort-keys": "error",
    "sort-vars": "error"
  },
  "env": {
    "builtin": true
  },
  "options": {
    "typeAware": true,
    "typeCheck": true
  }
}
