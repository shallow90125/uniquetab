{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"ignorePatterns": ["v1/**"],
	"plugins": ["typescript", "unicorn", "oxc"],
	"categories": {
		"correctness": "error"
	},
	"rules": {
		"sort-imports": "error",
		"sort-keys": "error",
		"sort-vars": "error"
	},
	"env": {
		"builtin": true
	},
	"options": {
		"typeAware": true,
		"typeCheck": true
	}
}
