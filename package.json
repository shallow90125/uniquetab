{
  "name": "uniquetab",
  "version": "1.0.0",
  "description": "ブックマークに登録されたサイトで同一URLのタブが複数開かれることを防ぐChrome拡張機能",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.246",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFiles": [
      "./tests/setup.js"
    ],
    "collectCoverageFrom": [
      "services/**/*.js",
      "background.js",
      "popup.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ]
  }
}
